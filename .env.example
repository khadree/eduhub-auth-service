# Server configuration
PORT=4000
NODE_ENV=development
APP_URL=http://localhost:4000

# PostgreSQL connection
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=eduhub_auth
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Redis configuration
REDIS_URL=redis://localhost:6379

# JWT configuration
JWT_ACCESS_TOKEN_SECRET=replace-with-strong-secret
JWT_ACCESS_TOKEN_EXPIRES_IN=15m
JWT_REFRESH_TOKEN_SECRET=replace-with-refresh-secret
JWT_REFRESH_TOKEN_EXPIRES_IN=7d

# Password reset
RESET_TOKEN_EXPIRES_IN_MINUTES=30
EMAIL_FROM="EduHub Academy <no-reply@eduhub.academy>"
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASSWORD=your-smtp-password

# SSO placeholder
SSO_ALLOWED_PROVIDERS=google,azuread
